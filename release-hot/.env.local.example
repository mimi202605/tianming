# release-hot/.env.local.example
# 天命·运维凭据 + 服务器路径外置模板。复制为 release-hot/.env.local 后填真值。
#   cp release-hot/.env.local.example release-hot/.env.local
# .env.local 已被根 .gitignore 排除·绝不入库；本 .example 不含真值·可入库。
#
# 这些 release-hot/*.py 与 mobile/_deploy/explore.py 不会自动加载本文件——
# 运行前须把变量导入当前 shell 环境：
#   PowerShell:  $env:TIANMING_SSH_HOST='...'; $env:TIANMING_SSH_PASS='...'   # 逐条设
#   bash/zsh:    set -a; . release-hot/.env.local; set +a                      # 一次性 source
#
# 最低要求：TIANMING_SSH_HOST 与 TIANMING_SSH_PASS 必设·缺失时脚本直接报错退出。

# 生产机 SSH 地址（必填·无默认）
TIANMING_SSH_HOST=

# SSH 端口（可选·默认 2222）
TIANMING_SSH_PORT=2222

# SSH 用户（可选·默认 root）
TIANMING_SSH_USER=root

# SSH 密码（必填·无默认·绝不写进脚本或入库）
TIANMING_SSH_PASS=

# 服务器 /hot 热更目录（可选·默认为线上 openresty 站点下的 .../index/tianming/hot）
# 用于：fix-1.2.6.4-incremental / fix-incremental-1287 / probe-upload /
#       server-diag / server-unzip-1.2.6.4 / server-verify-1287 / finish-incremental-*
TIANMING_HOT_DIR=/opt/1panel/apps/openresty/openresty/www/sites/<your-api-host>/index/tianming/hot

# 服务器 /tianming 站点根目录（可选·HOT 的父目录·默认 .../index/tianming）
# 用于：server-diag / server-verify-1287（PARENT）· sync-changelog-only（REMOTE=SERVE/changelog.json）· explore（TM）
TIANMING_SERVE_DIR=/opt/1panel/apps/openresty/openresty/www/sites/<your-api-host>/index/tianming
