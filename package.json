{
  "name": "tianming",
  "version": "1.3.410",
  "description": "天命 AI历史模拟推演",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prepare-vendor": "cd web && node tools/download-bge-model.js",
    "prepare-vendor-hf": "cd web && node tools/download-bge-model.js --hf",
    "build:win": "npm run prepare-vendor && electron-builder --win",
    "build:mac": "npm run prepare-vendor && electron-builder --mac",
    "build:linux": "npm run prepare-vendor && electron-builder --linux",
    "build:win:nomodel": "electron-builder --win",
    "build:mac:nomodel": "electron-builder --mac",
    "build:linux:nomodel": "electron-builder --linux"
  },
  "_build_notes": {
    "prepare-vendor": "构建前自动跑·下载 bge-small-zh 量化模型 ~23MB 到 web/vendor/models/。CN 友好镜像。",
    "build:X:nomodel": "不下载模型·安装包小但首次启动需联网拉模型·适合 GitHub Pages 或测试构建"
  },
  "build": {
    "appId": "com.tianming.history",
    "productName": "天命",
    "buildVersion": "1.3.4.10",
    "artifactName": "天命-1.3.4.10-${arch}.${ext}",
    "directories": {
      "output": "E:\\版本\\测试版1.3.4.10"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://api.themisfitserspeople.top/tianming/releases/win/"
      }
    ],
    "files": [
      "main.js",
      "main-impl.js",
      "preload.js",
      "preload-impl.js",
      "web/**/*",
      "web/.hot-update-manifest.json",
      "!web/**/*.save.json",
      "!web/.playwright-cli/**/*",
      "!web/backups/**/*",
      "!web/dev-tools/**/*",
      "!web/godot/**/*",
      "!web/test-results/**/*",
      "!web/_screenshots/**/*",
      "!web/**/*.bak*",
      "!web/**/*.log",
      "!web/**/*.yml",
      "!web/preview/shots/**/*",
      "!web/preview/*verify*.png",
      "!web/.git-defunct-*/**/*",
      "!web/.git/**/*",
      "!web/_archive/**/*",
      "!web/_pw-scratch/**/*",
      "!web/generated_images/**/*",
      "!web/docs/**/*",
      "!web/scripts/**/*",
      "!web/tools/**/*",
      "!web/**/_codex*",
      "!web/**/_codex*/**/*",
      "!web/preview/**/*.{png,jpg,jpeg,webp,gif,bmp}",
      "web/preview/img/**/*",
      "!web/preview/**/_*",
      "scenarios/天启七年·九月（官方）.json",
      "scenarios/绍宋·建炎元年八月（官方）.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "web/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "天命"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "electron-updater": "^6.8.3"
  }
}
