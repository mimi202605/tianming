{
  "appId": "com.tianming.history",
  "appName": "天命",
  "webDir": "../web",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#1a1410"
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "CapacitorUpdater": {
      "autoUpdate": false,
      "appReadyTimeout": 20000,
      "autoDeleteFailed": true,
      "autoDeletePrevious": true,
      "directUpdate": true,
      "resetWhenUpdate": true
    }
  }
}
